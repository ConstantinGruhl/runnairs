# Postgres (control plane)
POSTGRES_USER=platform
POSTGRES_PASSWORD=platform
POSTGRES_DB=platform

# Postgres (sample CRM data, used by tools.postgres in demos)
SAMPLE_DB_USER=sample
SAMPLE_DB_PASSWORD=sample
SAMPLE_DB_NAME=sample

# Runtime mode
APP_ENV=development

# JWT signing secret for user sessions and run tokens
# For production, replace this with a long random value and set APP_ENV=production.
JWT_SECRET=changeme-dev-only

# Fernet key used to encrypt secrets at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PLATFORM_SECRETS_KEY=

# Optional: real LLM keys can be set per-workspace in the admin UI instead.
# Setting these here is only used by integration tests.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
